generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Holding {
  id           Int              @id @default(autoincrement())
  nombre       String           @unique
  logoUrl      String?
  logoPublicId String?

  empresas     HoldingEmpresa[]
  Sucursal     Sucursal[]
}

model HoldingEmpresa {
  id        Int @id @default(autoincrement())
  holdingId Int
  empresaId Int

  Holding   Holding @relation(fields: [holdingId], references: [id], onDelete: Cascade)
  Empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([holdingId, empresaId])
}

model Empresa {
  id                Int              @id @default(autoincrement())
  nombre            String
  rut               String?          @unique
  logoPublicId      String?
  logoUrl           String?
  razonSocial       String?
  encargadoNombre   String?
  encargadoCorreo   String?
  encargadoTelefono String?

  holdings          HoldingEmpresa[]
  Asignacion        Asignacion[]
  Asistencia        Asistencia[]
  Sucursal          Sucursal[]
  Tarifa            Tarifa[]
}

model Sucursal {
  id         Int      @id @default(autoincrement())
  nombre     String
  direccion  String?
  comuna     String?
  ciudad     String?
  activo     Boolean  @default(true)

  empresaId  Int
  holdingId  Int

  Empresa    Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  Holding    Holding  @relation(fields: [holdingId], references: [id], onDelete: Cascade)

  Asignacion Asignacion[]
  Asistencia Asistencia[]
  Tarifa     Tarifa[]

  @@unique([empresaId, holdingId, nombre])
}

model Asignacion {
  id           Int        @id @default(autoincrement())
  trabajadorId Int
  empresaId    Int
  sucursalId   Int?
  cargoId      Int
  fechaInicio  DateTime
  fechaFin     DateTime?

  Cargo        Cargo      @relation(fields: [cargoId], references: [id])
  Empresa      Empresa    @relation(fields: [empresaId], references: [id])
  Sucursal     Sucursal?  @relation(fields: [sucursalId], references: [id])
  Trabajador   Trabajador @relation(fields: [trabajadorId], references: [id])
}

model Asistencia {
  id           Int        @id @default(autoincrement())
  trabajadorId Int
  fecha        DateTime
  cargoId      Int
  empresaId    Int
  sucursalId   Int?
  observacion  String?
  estado       String     @default("A")
  horasExtras  Float      @default(0)
  turno        String     @default("diurno")

  Cargo        Cargo      @relation(fields: [cargoId], references: [id])
  Empresa      Empresa    @relation(fields: [empresaId], references: [id])
  Sucursal     Sucursal?  @relation(fields: [sucursalId], references: [id])
  Trabajador   Trabajador @relation(fields: [trabajadorId], references: [id])

  @@unique([trabajadorId, fecha, empresaId])
}

model Cargo {
  id         Int          @id @default(autoincrement())
  nombre     String       @unique

  Asignacion Asignacion[]
  Asistencia Asistencia[]
  Tarifa     Tarifa[]
}

model Tarifa {
  id             Int      @id @default(autoincrement())
  empresaId      Int
  sucursalId     Int
  cargoId        Int

  bonoAsistencia Float    @default(0)
  bonoColacion   Float    @default(0)
  bonoLocomocion Float    @default(0)
  bonoNoche      Float    @default(0)
  otrosBonos     Float    @default(0)
  sueldoBase     Float    @default(0)
  valorHoraExtra Float    @default(0)

  Cargo          Cargo    @relation(fields: [cargoId], references: [id])
  Empresa        Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  Sucursal       Sucursal @relation(fields: [sucursalId], references: [id], onDelete: Cascade)

  @@unique([empresaId, sucursalId, cargoId])
}

model Trabajador {
  id         Int          @id @default(autoincrement())
  nombre     String
  apellido   String
  rut        String       @unique
  telefono   String?
  email      String?
  activo     Boolean      @default(true)
  createdAt  DateTime     @default(now())

  Asignacion Asignacion[]
  Asistencia Asistencia[]
}

model Usuario {
  id       Int    @id @default(autoincrement())
  nombre   String
  email    String @unique
  password String
  rol      String @default("ADMIN")
}